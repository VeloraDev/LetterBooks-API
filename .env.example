# Application port (default: 3000)
PORT=3000

# PostgreSQL connection string (used by Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/letterbooks

# JWT secret for authentication
JWT_SECRET=jwt_secret

# CSRF protection secret (required if CSRF is enabled)
CSRF_SECRET=csrf_secret

# --- Docker configuration (used when running with docker compose) ---
PG_HOST=localhost
PG_PORT=5432
PG_USERNAME=postgres
PG_PASSWORD=password
PG_DATABASE=letterbooks
